#openssl rand -base64 32 | tr -d '\n'
STUDIO_SERVICE_KEY_ENCRYPTION_KEY=pass
NGINX_SHARED_TOKEN=pass
SERVICE_KEY_CACHE_TTL_SECONDS=60
SERVICE_KEY_VERSION_CHECK_TTL_SECONDS=5
SERVICE_KEY_FETCH_ERROR_TTL_SECONDS=2
SERVICE_KEY_VERIFY_TLS=true
STUDIO_CA_CERT_PATH=./authelia/ssl/ca.pem
AVATAR_PROCESS_MAX_CONCURRENCY=2
AVATAR_PROCESS_TIMEOUT_MS=15000
AVATAR_MAX_PIXELS=16000000
AVATAR_MAX_SOURCE_EDGE=8192
AVATAR_MAX_EDGE=512
VIPS_CONCURRENCY=1
STUDIO_CONTEXT_CACHE_TTL_SECONDS=5
ADMIN_GROUPS=admin
NGINX_HMAC_SECRET=pass
NGINX_HMAC_TOKEN_TTL=300
INTERNAL_HMAC_SECRET=pass
INTERNAL_HMAC_MAX_SKEW_SECONDS=60
SERVER_DOMAIN=<SEU_IP>
BACKEND_PROTO=https
TZ=America/Sao_Paulo
VECTOR_FLUENTD_ADDRESS=127.0.0.1:24224
USERSDB_INIT_IMAGE=alpine
AUTHELIA_IMAGE=authelia/authelia:4.39.20
STUDIO_HTTPS_PORT=9091
SNIPPETS_MANAGEMENT_FOLDER=/app/snippets
STUDIO_SLUG_IMAGE=ghcr.io/gustavomartins123/multitenant-studio:20290c7-context-v1
SUPABASE_STUDIO_COMMIT=20290c71bdc48bef1720bfe7d292f3b9e6154f7d
SUPABASE_STUDIO_REPOSITORY=https://github.com/supabase/supabase.git
DEFAULT_ORGANIZATION_NAME=postgres
SUPABASE_PUBLIC_URL=https://<SEU_IP>:9091


OPENAI_API_KEY='example-code'
OPENAI_API_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL='qwen3-coder-next'



POSTGRES_USER=nginx_user
POSTGRES_NGINX_PASSWORD=pass
POSTGRES_DB=nginx
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_NGINX_PASSWORD}@postgres:5432/${POSTGRES_DB}

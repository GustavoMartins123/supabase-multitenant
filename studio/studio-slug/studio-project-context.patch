 const DEFAULT_HEADERS = { Accept: 'application/json' }
 
+const STUDIO_PROJECT_PATH = /^\/project\/([a-z_][a-z0-9_]{2,39})(?:\/|$)/
+const STUDIO_PROJECT_HEADER = 'X-Studio-Project-Ref'
+
+export function getStudioProjectRef(pathname?: string) {
+  const currentPath = pathname ?? (typeof window === 'undefined' ? '' : window.location.pathname)
+  return currentPath.match(STUDIO_PROJECT_PATH)?.[1]
+}
+
+function isSameOriginStudioRequest(input: RequestInfo | URL) {
+  if (typeof window === 'undefined') return false
+
+  const rawUrl =
+    typeof input === 'string' ? input : input instanceof URL ? input.href : input.url
+
+  try {
+    const url = new URL(rawUrl, window.location.origin)
+    return url.origin === window.location.origin
+  } catch {
+    return false
+  }
+}
+
+function withStudioProjectContext(
+  input: RequestInfo | URL,
+  init?: RequestInit
+): RequestInit | undefined {
+  const projectRef = getStudioProjectRef()
+  if (!projectRef || !isSameOriginStudioRequest(input)) return init
+
+  const headers = new Headers(input instanceof Request ? input.headers : undefined)
+  new Headers(init?.headers).forEach((value, key) => headers.set(key, value))
+  headers.set(STUDIO_PROJECT_HEADER, projectRef)
+
+  return { ...init, headers }
+}

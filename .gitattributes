* text=auto eol=lf

# Source, configuration and templates must always remain LF.
*.sh text eol=lf
*.py text eol=lf
*.lua text eol=lf
*.dart text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.sql text eol=lf

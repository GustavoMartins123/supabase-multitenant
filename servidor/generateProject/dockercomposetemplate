#para subir estando no diretorio do projeto -> docker/projects/{{project_id}}
#docker compose -p {{project_id}} --env-file ../../.env --env-file .env up --build -d
name: supabase
x-vector-logging: &vector-logging
  driver: fluentd
  options:
    fluentd-address: ${VECTOR_FLUENTD_ADDRESS:-127.0.0.1:24224}
    fluentd-async: "true"
    fluentd-sub-second-precision: "true"

services:
  nginx:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: supabase-nginx-{{project_id}}
    restart: unless-stopped
    logging: *vector-logging
    environment:
      FILE_SIZE_LIMIT: ${FILE_SIZE_LIMIT}
    volumes:
      - ${HOST_PROJECT_ROOT}/servidor/auth_template:/usr/share/nginx/html:ro
    read_only: true
    tmpfs:
      - /tmp:rw,noexec,nosuid,size=64m
      - /var/cache/nginx:rw,noexec,nosuid,size=32m
      - /var/run:rw,noexec,nosuid,size=8m
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    networks:
      - rede-supabase
  auth:
    container_name: supabase-auth-{{project_id}}
    image: ${AUTH_IMAGE}
    restart: unless-stopped
    logging: *vector-logging
    env_file:
      - ../../.env
      - .env
    networks:
      - rede-supabase
    healthcheck:
      test:
        [
          "CMD",
          "wget",
          "--no-verbose",
          "--tries=1",
          "--spider",
          "http://localhost:9999/health"
        ]
      timeout: 5s
      interval: 5s
      retries: 3
    # depends_on:
    #   analytics:
    #     condition: service_healthy
    environment:
      GOTRUE_API_HOST: ${GOTRUE_API_HOST}
      GOTRUE_API_PORT: ${GOTRUE_API_PORT}
      API_EXTERNAL_URL: ${API_EXTERNAL_URL}

      GOTRUE_DB_DRIVER: ${GOTRUE_DB_DRIVER}
      GOTRUE_DB_DATABASE_URL: postgres://${AUTH_DB_USER}.{{project_id}}:${POSTGRES_PASSWORD}@${POSTGRES_POOLER}:${POOLER_PROXY_PORT_SESSION}/${POSTGRES_DATABASE}

      GOTRUE_SITE_URL: ${SITE_URL}
      GOTRUE_URI_ALLOW_LIST: ${ADDITIONAL_REDIRECT_URLS}
      GOTRUE_DISABLE_SIGNUP: ${DISABLE_SIGNUP}

      GOTRUE_JWT_ADMIN_ROLES: ${GOTRUE_JWT_ADMIN_ROLES}
      GOTRUE_JWT_AUD: ${GOTRUE_JWT_AUD}
      GOTRUE_JWT_DEFAULT_GROUP_NAME: ${GOTRUE_JWT_DEFAULT_GROUP_NAME}
      GOTRUE_JWT_EXP: ${JWT_EXPIRY}
      GOTRUE_JWT_SECRET: ${JWT_SECRET_PROJETO}

      GOTRUE_EXTERNAL_EMAIL_ENABLED: ${ENABLE_EMAIL_SIGNUP}
      GOTRUE_EXTERNAL_ANONYMOUS_USERS_ENABLED: ${ENABLE_ANONYMOUS_USERS}
      GOTRUE_MAILER_AUTOCONFIRM: ${ENABLE_EMAIL_AUTOCONFIRM}
      GOTRUE_MAILER_OTP_EXP: ${GOTRUE_MAILER_OTP_EXP}
      GOTRUE_PASSWORD_MIN_LENGTH: ${GOTRUE_PASSWORD_MIN_LENGTH}
      GOTRUE_EXTERNAL_IMPLICIT_FLOW_ENABLED: ${GOTRUE_EXTERNAL_IMPLICIT_FLOW_ENABLED}

      # Uncomment to bypass nonce check in ID Token flow. Commonly set to true when using Google Sign In on mobile.
      # GOTRUE_EXTERNAL_SKIP_NONCE_CHECK: true

      # GOTRUE_MAILER_SECURE_EMAIL_CHANGE_ENABLED: true
      # GOTRUE_SMTP_MAX_FREQUENCY: 1s
      GOTRUE_MAILER_TEMPLATES_RECOVERY: ${GOTRUE_MAILER_TEMPLATES_BASE_URL}/recovery.html
      GOTRUE_MAILER_TEMPLATES_INVITE: ${GOTRUE_MAILER_TEMPLATES_BASE_URL}/invite.html
      GOTRUE_MAILER_TEMPLATES_CONFIRMATION: ${GOTRUE_MAILER_TEMPLATES_BASE_URL}/confirmation.html
      GOTRUE_MAILER_TEMPLATES_EMAIL_CHANGE: ${GOTRUE_MAILER_TEMPLATES_BASE_URL}/email_change.html
      GOTRUE_MAILER_TEMPLATES_MAGIC_LINK: ${GOTRUE_MAILER_TEMPLATES_BASE_URL}/magiclink.html
      GOTRUE_MAILER_SUBJECTS_INVITE: ${MAILER_SUBJECTS_INVITE}
      GOTRUE_MAILER_SUBJECTS_RECOVERY: ${MAILER_SUBJECTS_RECOVERY}
      GOTRUE_MAILER_SUBJECTS_MAGIC_LINK: ${MAILER_SUBJECTS_MAGIC_LINK}
      GOTRUE_MAILER_SUBJECTS_CONFIRMATION: ${MAILER_SUBJECTS_CONFIRMATION}
      GOTRUE_MAILER_SUBJECTS_EMAIL_CHANGE: ${MAILER_SUBJECTS_EMAIL_CHANGE}
      GOTRUE_SMTP_ADMIN_EMAIL: ${SMTP_ADMIN_EMAIL}
      GOTRUE_SMTP_HOST: ${SMTP_HOST}
      GOTRUE_SMTP_PORT: ${SMTP_PORT}
      GOTRUE_SMTP_USER: ${SMTP_USER}
      GOTRUE_SMTP_PASS: ${SMTP_PASS}
      GOTRUE_SMTP_SENDER_NAME: ${SMTP_SENDER_NAME}
      GOTRUE_MAILER_URLPATHS_INVITE: ${MAILER_URLPATHS_INVITE}
      GOTRUE_MAILER_URLPATHS_CONFIRMATION: ${MAILER_URLPATHS_CONFIRMATION}
      GOTRUE_MAILER_URLPATHS_RECOVERY: ${MAILER_URLPATHS_RECOVERY}
      GOTRUE_MAILER_URLPATHS_EMAIL_CHANGE: ${MAILER_URLPATHS_EMAIL_CHANGE}
      GOTRUE_MAILER_URLPATHS_MAGIC_LINK: ${MAILER_URLPATHS_MAGIC_LINK}

      GOTRUE_EXTERNAL_PHONE_ENABLED: ${ENABLE_PHONE_SIGNUP}
      GOTRUE_SMS_AUTOCONFIRM: ${ENABLE_PHONE_AUTOCONFIRM}
      # Uncomment to enable custom access token hook. Please see: https://supabase.com/docs/guides/auth/auth-hooks for full list of hooks and additional details about custom_access_token_hook

      # GOTRUE_HOOK_CUSTOM_ACCESS_TOKEN_ENABLED: "true"
      # GOTRUE_HOOK_CUSTOM_ACCESS_TOKEN_URI: "pg-functions://postgres/public/custom_access_token_hook"
      # GOTRUE_HOOK_CUSTOM_ACCESS_TOKEN_SECRETS: "<standard-base64-secret>"

      # GOTRUE_HOOK_MFA_VERIFICATION_ATTEMPT_ENABLED: "true"
      # GOTRUE_HOOK_MFA_VERIFICATION_ATTEMPT_URI: "pg-functions://postgres/public/mfa_verification_attempt"

      # GOTRUE_HOOK_PASSWORD_VERIFICATION_ATTEMPT_ENABLED: "true"
      # GOTRUE_HOOK_PASSWORD_VERIFICATION_ATTEMPT_URI: "pg-functions://postgres/public/password_verification_attempt"

      # GOTRUE_HOOK_SEND_SMS_ENABLED: "false"
      # GOTRUE_HOOK_SEND_SMS_URI: "pg-functions://postgres/public/custom_access_token_hook"
      # GOTRUE_HOOK_SEND_SMS_SECRETS: "v1,whsec_VGhpcyBpcyBhbiBleGFtcGxlIG9mIGEgc2hvcnRlciBCYXNlNjQgc3RyaW5n"

      # GOTRUE_HOOK_SEND_EMAIL_ENABLED: "false"
      # GOTRUE_HOOK_SEND_EMAIL_URI: "http://host.docker.internal:54321/functions/v1/email_sender"
      # GOTRUE_HOOK_SEND_EMAIL_SECRETS: "v1,whsec_VGhpcyBpcyBhbiBleGFtcGxlIG9mIGEgc2hvcnRlciBCYXNlNjQgc3RyaW5n"

  rest:
    container_name: supabase-rest-{{project_id}}
    image: ${POSTGREST_IMAGE}
    restart: unless-stopped
    logging: *vector-logging
    env_file:
      - ../../.env
      - .env
    networks:
      - rede-supabase
    # depends_on:
    #   db:
    #     # Disable this if you are using an external Postgres database
    #     condition: service_healthy
    #   analytics:
    #     condition: service_healthy
    environment:
      PGRST_DB_URI: postgres://${POSTGREST_DB_USER}.{{project_id}}:${POSTGRES_PASSWORD}@${POSTGRES_POOLER}:${POOLER_PROXY_PORT_SESSION}/${POSTGRES_DATABASE}
      PGRST_DB_SCHEMA_CACHE_DURATION: ${PGRST_DB_SCHEMA_CACHE_DURATION}
      PGRST_DB_SCHEMAS: ${PGRST_DB_SCHEMAS}
      PGRST_DB_ANON_ROLE: ${PGRST_DB_ANON_ROLE}
      PGRST_JWT_SECRET: ${JWT_SECRET_PROJETO}
      PGRST_DB_USE_LEGACY_GUCS: ${PGRST_DB_USE_LEGACY_GUCS}
      PGRST_DB_PREPARED_STATEMENTS: ${PGRST_DB_PREPARED_STATEMENTS}
      PGRST_APP_SETTINGS_JWT_SECRET: ${JWT_SECRET_PROJETO}
      PGRST_APP_SETTINGS_JWT_EXP: ${JWT_EXPIRY}
      PGRST_DB_MAX_ROWS: ${PGRST_DB_MAX_ROWS}
      PGRST_DB_POOL: ${PGRST_DB_POOL}
      PGRST_DB_POOL_TIMEOUT: ${PGRST_DB_POOL_TIMEOUT}
      PGRST_DB_POOL_ACQUISITION_TIMEOUT: ${PGRST_DB_POOL_ACQUISITION_TIMEOUT}
    command:
      [
        "postgrest"
      ]
  # To use S3 backed storage: docker compose -f docker-compose.yml -f docker-compose.s3.yml up
  storage:
    container_name: supabase-storage-{{project_id}}
    image: ${STORAGE_IMAGE}
    restart: unless-stopped
    logging: *vector-logging
    env_file:
      - ../../.env
      - .env
    networks:
      - rede-supabase
    volumes:
      - ${HOST_PROJECT_ROOT}/servidor/projects/{{project_id}}/storage:/var/lib/storage:z
    healthcheck:
      test:
        [
          "CMD",
          "wget",
          "--no-verbose",
          "--tries=1",
          "--spider",
          "http://storage:5000/status"
        ]
      timeout: 5s
      interval: 5s
      retries: 3
    depends_on:
      rest:
        condition: service_started
      imgproxy:
        condition: service_started
    environment:
      ANON_KEY: ${ANON_KEY_PROJETO}
      SERVICE_KEY: ${SERVICE_ROLE_KEY_PROJETO}
      POSTGREST_URL: ${STORAGE_POSTGREST_URL}
      PGRST_JWT_SECRET: ${JWT_SECRET_PROJETO}
      DATABASE_URL: postgres://${STORAGE_DB_USER}.{{project_id}}:${POSTGRES_PASSWORD}@${POSTGRES_POOLER}:${POOLER_PROXY_PORT_TRANSACTION}/${POSTGRES_DATABASE}
      FILE_SIZE_LIMIT: ${FILE_SIZE_LIMIT}
      STORAGE_BACKEND: ${STORAGE_BACKEND}

      #Permite usar o Tus
      REQUEST_ALLOW_X_FORWARDED_PATH: ${REQUEST_ALLOW_X_FORWARDED_PATH}
      TUS_URL_PATH: ${TUS_URL_PATH}


      FILE_STORAGE_BACKEND_PATH: ${FILE_STORAGE_BACKEND_PATH}
      TENANT_ID: ${STORAGE_TENANT_ID}
      # TODO: https://github.com/supabase/storage-api/issues/55
      REGION: ${STORAGE_REGION}
      GLOBAL_S3_BUCKET: ${GLOBAL_S3_BUCKET}
      ENABLE_IMAGE_TRANSFORMATION: ${ENABLE_IMAGE_TRANSFORMATION}
      IMGPROXY_URL: ${IMGPROXY_URL}

  imgproxy:
    container_name: supabase-imgproxy-{{project_id}}
    image: ${IMGPROXY_IMAGE}
    restart: unless-stopped
    logging: *vector-logging
    networks:
      - rede-supabase
    volumes:
      - ${HOST_PROJECT_ROOT}/servidor/projects/{{project_id}}/storage:/var/lib/storage:z
    healthcheck:
      test:
        [
          "CMD",
          "imgproxy",
          "health"
        ]
      timeout: 5s
      interval: 5s
      retries: 3
    environment:
      IMGPROXY_BIND: ${IMGPROXY_BIND}
      IMGPROXY_LOCAL_FILESYSTEM_ROOT: ${IMGPROXY_LOCAL_FILESYSTEM_ROOT}
      IMGPROXY_USE_ETAG: ${IMGPROXY_USE_ETAG}
      IMGPROXY_ENABLE_WEBP_DETECTION: ${IMGPROXY_ENABLE_WEBP_DETECTION}

networks:
  rede-supabase:
    external: true

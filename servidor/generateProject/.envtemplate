PROJECT_ID={{project_id}}
PROJECT_UUID={{project_uuid}}
POSTGRES_DATABASE=_supabase_{{project_id}}
PROJECT_ROOT={{project_root}}

AUTH_IMAGE=supabase/gotrue:v2.193.0-rc.3
GOTRUE_API_HOST=0.0.0.0
GOTRUE_API_PORT=9999
GOTRUE_DB_DRIVER=postgres
GOTRUE_JWT_ADMIN_ROLES=service_role
GOTRUE_JWT_AUD=authenticated
GOTRUE_JWT_DEFAULT_GROUP_NAME=authenticated
AUTH_DB_USER=supabase_auth_admin
GOTRUE_MAILER_TEMPLATES_BASE_URL=http://supabase-nginx-{{project_id}}:8080
POSTGREST_IMAGE=postgrest/postgrest:v14.14
POSTGREST_DB_USER=authenticator
PGRST_DB_SCHEMA_CACHE_DURATION=20
PGRST_DB_ANON_ROLE=anon
PGRST_DB_USE_LEGACY_GUCS=false
PGRST_DB_PREPARED_STATEMENTS=true
STORAGE_IMAGE=supabase/storage-api:v1.61.12
STORAGE_DB_USER=supabase_storage_admin
STORAGE_POSTGREST_URL=http://rest:3000
STORAGE_BACKEND=file
REQUEST_ALLOW_X_FORWARDED_PATH=true
TUS_URL_PATH=/storage/v1/upload/resumable
FILE_STORAGE_BACKEND_PATH=/var/lib/storage
STORAGE_TENANT_ID=stub
STORAGE_REGION=stub
GLOBAL_S3_BUCKET=stub
VECTOR_ENABLED=true
VECTOR_BUCKET_PROVIDER=pgvector
VECTOR_DATABASE_URL=postgres://${STORAGE_DB_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DATABASE}
VECTOR_DATABASE_CREATE=false
VECTOR_STORE_MIGRATIONS_ENABLED=true
# Preenchidas automaticamente por enable_vector_storage.sh. Elas autenticam o
# protocolo S3 Vectors usado pelo Wrappers FDW; nao sao as chaves JWT do projeto.
S3_PROTOCOL_ENABLED=true
S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=
IMGPROXY_URL=http://imgproxy:5001
IMGPROXY_IMAGE=darthsim/imgproxy:v4.0.11
IMGPROXY_BIND=:5001
IMGPROXY_LOCAL_FILESYSTEM_ROOT=/
IMGPROXY_USE_ETAG=true



SITE_URL={{project_public_url}}/verify-success.html
ADDITIONAL_REDIRECT_URLS={{project_public_url}}/verify-success.html
DISABLE_SIGNUP=false
API_EXTERNAL_URL={{project_auth_external_url}}
JWT_EXPIRY=3600
GOTRUE_MAILER_OTP_EXP=1800
GOTRUE_PASSWORD_MIN_LENGTH=6
GOTRUE_EXTERNAL_IMPLICIT_FLOW_ENABLED=false

MAILER_URLPATHS_CONFIRMATION="/verify"
MAILER_URLPATHS_INVITE="/verify"
MAILER_URLPATHS_RECOVERY="/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/verify"
MAILER_URLPATHS_MAGIC_LINK="/verify"
MAILER_SUBJECTS_INVITE="Você foi convidado"
MAILER_SUBJECTS_RECOVERY="Redefinir sua senha"
MAILER_SUBJECTS_MAGIC_LINK="Seu link de acesso"
MAILER_SUBJECTS_CONFIRMATION="Confirme seu cadastro"
MAILER_SUBJECTS_EMAIL_CHANGE="Confirme a alteração de e-mail"

ENABLE_EMAIL_SIGNUP=true
#important -> default is false
ENABLE_EMAIL_AUTOCONFIRM=true
#important -> default is false
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

PGRST_DB_SCHEMAS=public
PGRST_DB_MAX_ROWS=200000
PGRST_DB_POOL=100
PGRST_DB_POOL_TIMEOUT=60
PGRST_DB_POOL_ACQUISITION_TIMEOUT=60

FILE_SIZE_LIMIT=524288000
IMGPROXY_ENABLE_WEBP_DETECTION=true
ENABLE_IMAGE_TRANSFORMATION=true

# Optional per-project SMTP override
# SMTP_ADMIN_EMAIL=noreply.example@example.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply.example@example.com
# SMTP_PASS='supersecretpassword'
# SMTP_SENDER_NAME="Supabase"

ANON_KEY_PROJETO={{anon_key}}
SERVICE_ROLE_KEY_PROJETO={{service_role_key}}
CONFIG_TOKEN_PROJETO={{config_token}}
JWT_SECRET_PROJETO={{jwt_secret}}
